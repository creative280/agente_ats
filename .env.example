# === API Keys (NUNCA subir este archivo a git) ===
# Copia este archivo como .env y pon tus keys reales ahí
GROQ_API_KEY=gsk_tu-key-de-groq

# === OpenAI (opcional, de pago) ===
# OPENAI_API_KEY=sk-tu-key-aqui

# === Gemini (opcional) ===
# GEMINI_API_KEY=tu-key-aqui

# === Telegram (Fase 2) ===
TELEGRAM_BOT_TOKEN=tu-token-de-botfather

# === WhatsApp Cloud API (Fase 2) ===
WHATSAPP_TOKEN=tu-token-meta
WHATSAPP_PHONE_ID=tu-phone-id
WHATSAPP_VERIFY_TOKEN=un-token-secreto-tuyo
WHATSAPP_APP_SECRET=tu-app-secret

# === Base de datos (Fase 4) ===
DATABASE_URL=postgresql://agente_user:password@localhost:5432/agente_db
REDIS_URL=redis://localhost:6379/0
DB_PASSWORD=tu-password-seguro

# === n8n (Fase 5) ===
N8N_PASSWORD=tu-password-n8n
